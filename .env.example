# ─── Postgres ──────────────────────────────────────────
POSTGRES_USER=emercado
POSTGRES_PASSWORD=CHANGE_ME_postgres_secret
DATABASE_URL=postgresql+asyncpg://emercado:CHANGE_ME_postgres_secret@postgres:5432/estudos_mercado

# ─── MinIO ─────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=estudos-mercado

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ─── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME

# ─── SMTP (notifications) ─────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@example.com

# ─── ClamAV ───────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ─── PII Encryption ──────────────────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_KEY=CHANGE_ME_generate_with_fernet

# ─── Frontend ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api

# ─── Ports ─────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ─── Edition (community | pro) ────────────────────────
# community = free, open-source tier (AI modules disabled)
# pro       = full-featured (requires COGNIRA_LICENSE_KEY)
EDITION=community
# COGNIRA_LICENSE_KEY=your_license_key_here

# ─── WebRTC TURN server (coturn) ─────────────────────
# Generate: openssl rand -hex 32
TURN_SECRET=CHANGE_ME_turn_secret
TURN_HOST=

# ─── Web Push / VAPID ────────────────────────────────
# Generate: python3 -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('private:', v.private_key); print('public:', v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ─── SSO / OIDC (Authentik, Keycloak, Azure AD, Google…) ──────────────────────
# Set SSO_ENABLED=true and fill the remaining vars to activate.
# For Authentik: create an OAuth2/OIDC Provider in your Authentik instance,
# then create an Application pointing to that provider.
SSO_ENABLED=false
SSO_PROVIDER_NAME=Authentik
SSO_CLIENT_ID=CHANGE_ME
SSO_CLIENT_SECRET=CHANGE_ME
# Authentik example (replace YOUR_AUTHENTIK_HOST and APP_SLUG):
SSO_AUTH_URL=https://YOUR_AUTHENTIK_HOST/application/o/APP_SLUG/authorize/
SSO_TOKEN_URL=https://YOUR_AUTHENTIK_HOST/application/o/APP_SLUG/token/
SSO_USERINFO_URL=https://YOUR_AUTHENTIK_HOST/application/o/userinfo/
# Must match the Redirect URI configured in Authentik:
SSO_REDIRECT_URI=https://YOUR_APP_HOST/api/auth/sso/callback
SSO_SCOPES=openid email profile
# Role assigned to new users auto-provisioned via SSO:
SSO_DEFAULT_ROLE=utilizador

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
# Webhook secret — from Stripe Dashboard > Webhooks > your endpoint
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# Stripe Price IDs for each plan — create in Dashboard > Product catalogue
STRIPE_PRICE_STARTER=price_CHANGE_ME
STRIPE_PRICE_PROFESSIONAL=price_CHANGE_ME
STRIPE_PRICE_ENTERPRISE=price_CHANGE_ME
